rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read, delete: if request.auth != null && (request.auth.token.email == 'debashiskhan586@gmail.com' || request.auth.token.email == 'hintonevolution@gmail.com');
    }
  }
}