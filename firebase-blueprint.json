{
  "entities": {
    "Inquiry": {
      "title": "Inquiry",
      "description": "User project inquiry submission from the Contact form",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the inquirer" },
        "phone": { "type": "string", "description": "Phone or Whatsapp number" },
        "email": { "type": "string", "format": "email", "description": "Email address for contact" },
        "service": { "type": "string", "description": "Type of service requested" },
        "projectType": { "type": "string", "description": "Type of project requested" },
        "budget": { "type": "string", "description": "Budget range for the project" },
        "description": { "type": "string", "description": "Brief description of the project" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of submission" }
      },
      "required": ["name", "phone", "email", "service", "projectType", "budget", "createdAt"]
    }
  },
  "firestore": {
    "inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Collection of all project inquiries"
    }
  }
}
